{
  "name": "acuity-clone",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "acuity-clone",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@acuity/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "packages/contracts": {
      "name": "@acuity/contracts",
      "version": "0.1.0"
    }
  }
}
