{
  "name": "acuity-clone",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "acuity-clone",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@acuity/api",
      "version": "0.1.0"
    },
    "apps/web": {
      "name": "@acuity/web",
      "version": "0.1.0"
    },
    "apps/worker": {
      "name": "@acuity/worker",
      "version": "0.1.0"
    },
    "node_modules/@acuity/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@acuity/config": {
      "resolved": "packages/config",
      "link": true
    },
    "node_modules/@acuity/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@acuity/db": {
      "resolved": "packages/db",
      "link": true
    },
    "node_modules/@acuity/testing": {
      "resolved": "packages/testing",
      "link": true
    },
    "node_modules/@acuity/ui": {
      "resolved": "packages/ui",
      "link": true
    },
    "node_modules/@acuity/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/@acuity/worker": {
      "resolved": "apps/worker",
      "link": true
    },
    "packages/config": {
      "name": "@acuity/config",
      "version": "0.1.0"
    },
    "packages/contracts": {
      "name": "@acuity/contracts",
      "version": "0.1.0"
    },
    "packages/db": {
      "name": "@acuity/db",
      "version": "0.1.0"
    },
    "packages/testing": {
      "name": "@acuity/testing",
      "version": "0.1.0"
    },
    "packages/ui": {
      "name": "@acuity/ui",
      "version": "0.1.0"
    }
  }
}
