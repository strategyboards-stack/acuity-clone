{
  "name": "acuity-clone",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "acuity-clone",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@acuity/api",
      "version": "0.1.0",
      "dependencies": {
        "@acuity/contracts": "0.1.0"
      }
    },
    "node_modules/@acuity/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@acuity/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "packages/contracts": {
      "name": "@acuity/contracts",
      "version": "0.1.0"
    }
  }
}
