{
  "name": "acuity-clone",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "acuity-clone",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/web": {
      "name": "@acuity/web"
    },
    "node_modules/@acuity/contracts": {
      "resolved": "packages/contracts",
      "link": true
    },
    "node_modules/@acuity/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/contracts": {
      "name": "@acuity/contracts",
      "version": "0.0.0"
    }
  }
}
